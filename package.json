{
	"name": "@almeidx/discore",
	"version": "0.1.0",
	"description": "A lightweight, functional Discord bot framework built on @discordjs/core",
	"keywords": [
		"bot",
		"commands",
		"core",
		"discord",
		"discordjs",
		"framework"
	],
	"homepage": "https://github.com/almeidx/discore#readme",
	"bugs": "https://github.com/almeidx/discore/issues",
	"license": "Apache-2.0",
	"author": "almeidx (https://almeidx.dev)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/discore.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"scripts": {
		"build": "tsdown",
		"build:typecheck": "tsc --noEmit",
		"fmt": "oxfmt --write && oxlint --fix",
		"lint": "oxfmt --check && oxlint",
		"prepack": "pnpm build",
		"test": "node --test './test/**/*.test.ts'",
		"prepare": "husky .github/husky"
	},
	"devDependencies": {
		"@discordjs/core": "3.0.0-dev.1772884937-84b85f4c9",
		"@discordjs/rest": "3.0.0-dev.1772884937-84b85f4c9",
		"@discordjs/ws": "3.0.0-dev.1772884937-84b85f4c9",
		"discord-api-types": "^0.38.41",
		"husky": "^9.1.7",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.51.0",
		"tsdown": "^0.21.0",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"@discordjs/core": ">=3.0.0-dev"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.30.3"
}
