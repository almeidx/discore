{
	"name": "@almeidx/discore",
	"version": "0.0.1",
	"description": "A lightweight, functional Discord bot framework built on @discordjs/core",
	"keywords": [
		"bot",
		"commands",
		"core",
		"discord",
		"discordjs",
		"framework"
	],
	"homepage": "https://github.com/almeidx/discore#readme",
	"bugs": "https://github.com/almeidx/discore/issues",
	"license": "Apache-2.0",
	"author": "almeidx (https://almeidx.dev)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/almeidx/discore.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"build:typecheck": "tsc --noEmit",
		"fmt": "oxfmt --write && oxlint --fix",
		"lint": "oxfmt --check && oxlint",
		"prepack": "pnpm build",
		"prepare": "husky .github/husky",
		"test": "node --test './test/**/*.test.ts'"
	},
	"devDependencies": {
		"@discordjs/collection": "3.0.0-dev.1776730371-8ea7c7c7e",
		"@discordjs/core": "3.0.0-dev.1776730371-8ea7c7c7e",
		"@discordjs/rest": "3.0.0-dev.1776730371-8ea7c7c7e",
		"@discordjs/ws": "3.0.0-dev.1776730371-8ea7c7c7e",
		"discord-api-types": "^0.38.47",
		"husky": "^9.1.7",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"tsdown": "^0.21.10",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@discordjs/collection": ">=3.0.0-dev",
		"@discordjs/core": ">=3.0.0-dev",
		"@discordjs/ws": ">=3.0.0-dev.1776125601-58c5ebdd0",
		"discord-api-types": ">=0.38.47"
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"packageManager": "pnpm@10.33.1"
}
